# Copy this file to .env and fill in your real values.
# All of these are SERVER-ONLY secrets — never expose them to the browser.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional extra sources (the app still runs on Adzuna + Reed without them).
JOOBLE_API_KEY=
JSEARCH_API_KEY=
# "openwebninja" (default) or "rapidapi"
JSEARCH_PROVIDER=openwebninja

# Login (Supabase Auth). These two are PUBLISHABLE — safe to expose to the
# browser; row-level security protects the data. They are NOT secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
